<section class="classy-section py-5">
    <div class="container">
        <h2 class="mb-4 text-secondary fw-bold border-bottom pb-2 d-flex align-items-center">
            <i class="bi bi-cart me-2 text-primary"></i> Your Shopping Cart
        </h2>

        <% if (cart && cart.length > 0) { %>
            <!-- Move All to Wishlist button -->
            <div class="d-flex justify-content-end mb-3">
                <form method="post" action="/cart/move-all-to-wishlist">
                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill classy-btn">
                        <i class="bi bi-heart me-1"></i> Move All to Wishlist
                    </button>
                </form>
            </div>

            <div class="row g-4"> <!-- ✅ added gutter spacing -->
                <% let total = 0; %>
                <% cart.forEach(item => {
                    const subtotal = item.price * item.quantity;
                    total += subtotal;
                %>
                <div class="col-lg-4 col-md-6 fade-in-card"> <!-- ✅ responsive columns -->
                    <div class="card h-100 border-0 rounded-4 shadow-sm classy-card hover-zoom">
                        <!-- Book image + title -->
                        <div class="d-flex align-items-center p-3 border-bottom">
                            <% if (item.image) { %>
                                <img src="<%= item.image.startsWith('http') || item.image.startsWith('/uploads/books/') ? item.image : '/uploads/books/' + item.image %>"
                                     alt="<%= item.title %>"
                                     class="rounded me-3"
                                     style="width:60px; height:auto;">
                            <% } else { %>
                                <img src="/images/default-book.png"
                                     alt="No cover"
                                     class="rounded me-3"
                                     style="width:60px; height:auto;">
                            <% } %>
                            <div>
                                <a href="/book/<%= item.book_id %>" class="fw-bold text-dark classy-link">
                                    <%= item.title %>
                                </a>
                                <p class="text-muted small mb-0">₹<%= item.price %> each</p>
                            </div>
                        </div>

                        <!-- Quantity + Subtotal -->
                        <div class="card-body p-3">
                            <form method="post" action="/cart/update" class="mb-3 classy-quantity">
                                <div class="d-flex align-items-center justify-content-center gap-2">
                                    <!-- Decrease button -->
                                    <button type="submit" name="action" value="decrease-<%= item.book_id %>"
                                            class="btn btn-outline-secondary rounded-pill classy-btn classy-qty-btn"
                                            <%= item.quantity <= 1 ? 'disabled' : '' %>
                                            title="<%= item.quantity <= 1 ? 'Minimum quantity reached' : 'Decrease quantity' %>">
                                        <i class="bi bi-dash-lg <%= item.quantity <= 1 ? 'text-muted' : '' %>"></i>
                                    </button>

                                    <!-- Quantity badge -->
                                    <span class="badge bg-light text-dark fw-bold px-3 py-2 rounded-pill shadow-sm classy-qty-value">
                                        <%= item.quantity %>
                                    </span>

                                    <!-- Increase button -->
                                    <button type="submit" name="action" value="increase-<%= item.book_id %>"
                                            class="btn btn-outline-secondary rounded-pill classy-btn classy-qty-btn"
                                            <%= item.quantity >= item.stock ? 'disabled' : '' %>
                                            title="<%= item.quantity >= item.stock ? 'Stock limit reached' : 'Increase quantity' %>">
                                        <i class="bi bi-plus-lg <%= item.quantity >= item.stock ? 'icon-disabled' : '' %>"></i>
                                    </button>
                                </div>

                                <!-- Inline warning when stock limit reached -->
                                <% if (item.quantity >= item.stock) { %>
                                    <div class="text-danger small mt-2">
                                        <i class="bi bi-exclamation-triangle me-1"></i>
                                        Maximum stock reached
                                    </div>
                                <% } %>
                            </form>

                            <p class="fw-bold text-success mb-2">Subtotal: ₹<%= subtotal %></p>

                            <!-- Action buttons -->
                            <div class="d-flex flex-column gap-2">
                                <form method="post" action="/cart/update">
                                    <button type="submit" name="action" value="remove-<%= item.book_id %>"
                                            class="btn btn-sm btn-danger rounded-pill classy-btn"
                                            onclick="return confirm('Remove <%= item.title %> from cart?');">
                                        <i class="bi bi-trash"></i> Remove
                                    </button>
                                </form>
                                <form method="post" action="/cart/move-to-wishlist/<%= item.book_id %>">
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill classy-btn">
                                        <i class="bi bi-heart"></i> Move to Wishlist
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>

            <!-- Cart Total -->
            <div class="d-flex justify-content-between align-items-center mt-4 border-top pt-3">
                <h4 class="fw-bold">Total: ₹<%= total %></h4>
                <form method="post" action="/cart/checkout">
                    <button type="submit" class="btn btn-lg btn-success rounded-pill classy-btn explore-btn">
                        <i class="bi bi-credit-card me-2"></i> Proceed to Checkout
                    </button>
                </form>
            </div>
        <% } else { %>
            <div class="alert alert-info mt-4 rounded-4 shadow-sm text-center">
                <i class="bi bi-info-circle me-2"></i> Your cart is empty.
                <a href="/books" class="alert-link">Browse books</a> to add items.
            </div>
        <% } %>
    </div>
</section>

<script>
    // Fade-in animation
    document.addEventListener("DOMContentLoaded", () => {
        const cards = document.querySelectorAll(".fade-in-card");
        const observer = new IntersectionObserver(entries => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("visible");
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.2 });
        cards.forEach(card => observer.observe(card));
    });

    // Pulse animation for quantity badge
    document.addEventListener("DOMContentLoaded", () => {
        const qtyValues = document.querySelectorAll(".classy-qty-value");
        qtyValues.forEach(qty => {
            const observer = new MutationObserver(() => {
                qty.classList.add("pulse");
                setTimeout(() => qty.classList.remove("pulse"), 500);
            });
            observer.observe(qty, { childList: true });
        });
    });
</script>

<style>
    .fade-in-card { opacity: 0; transform: translateY(20px); transition: all 0.6s ease-in-out; }
    .fade-in-card.visible { opacity: 1; transform: translateY(0); }
    .pulse { animation: pulse 0.5s; }
    @keyframes pulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.1); }
        100% { transform: scale(1); }
    }
</style>