<div class="container my-5 text-center">
    <!-- Animated Checkmark -->
    <div class="checkmark-wrapper mb-4">
        <div class="checkmark-circle">
            <div class="checkmark-stem"></div>
            <div class="checkmark-kick"></div>
        </div>
    </div>

    <!-- Success Message -->
    <h2 class="text-success fw-bold mb-3">Order Placed Successfully!</h2>
    <p class="lead text-muted">Thank you for shopping with us. Your order is on its way!</p>

    <!-- Order Summary -->
    <div class="mt-4 text-start d-inline-block">
        <h5 class="fw-bold">Order Details</h5>
        <p><strong>Order ID:</strong> <%= orderId %></p>
        <p><strong>Total Amount:</strong> ₹<%= total %></p>
        <p><strong>Payment Mode:</strong>
            <%= payment_mode === 'COD' ? 'Cash on Delivery' : 'Online Payment (Razorpay)' %>
        </p>

        <h6 class="mt-3">Items:</h6>
        <ul class="list-group text-start">
            <% cart.forEach(item => { %>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span>
                        <img src="<%= item.image %>" alt="Book cover of <%= item.title %>" width="40" class="me-2 rounded">
                        <%= item.title %>
                    </span>
                    <span class="badge bg-primary rounded-pill">Qty: <%= item.quantity %></span>
                    <span class="text-muted">₹<%= item.price * item.quantity %></span>
                </li>
            <% }) %>
        </ul>
    </div>

    <!-- Continue Shopping -->
    <div class="mt-4">
        <a href="/books" class="btn btn-outline-primary rounded-pill">
            <i class="bi bi-arrow-left-circle me-2"></i> Continue Shopping
        </a>
    </div>
</div>

<!-- Styles -->
<style>
    .checkmark-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
    }
    .checkmark-circle {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: #4CAF50;
        position: relative;
        animation: pop 0.4s ease-out;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }
    .checkmark-stem {
        position: absolute;
        width: 5px;
        height: 25px;
        background: white;
        top: 28px;
        left: 42px;
        transform: rotate(-45deg);
        border-radius: 2px;
    }
    .checkmark-kick {
        position: absolute;
        width: 5px;
        height: 12px;
        background: white;
        top: 46px;
        left: 32px;
        transform: rotate(45deg);
        border-radius: 2px;
    }
    @keyframes pop {
        0% { transform: scale(0.5); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
    }
</style>

<!-- Auto Redirect -->
<script>
    setTimeout(() => {
        window.location.href = "/books"; // redirect after 5 seconds
    }, 5000);
</script>