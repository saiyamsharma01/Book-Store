<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>KBooks - Feedback</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
</head>

<body>
<div class="container my-5 classy-section">
    <!-- Page Title -->
    <h2 class="mb-4 text-secondary fw-bold border-bottom pb-2 d-flex align-items-center">
        <i class="bi bi-chat-dots me-2 text-primary"></i> Share Your Feedback
    </h2>


    <!-- Flash Messages -->
    <% if (flash && flash.success && Array.isArray(flash.success) && flash.success.length > 0) { %>
        <div class="alert alert-success rounded-4 shadow-sm">
            <i class="bi bi-check-circle-fill me-2"></i> <%= flash.success[0] %>
        </div>
    <% } %>

    <% if (flash && flash.error && Array.isArray(flash.error) && flash.error.length > 0) { %>
        <div class="alert alert-danger rounded-4 shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= flash.error[0] %>
        </div>
    <% } %>

    <!-- Feedback Form -->
    <form method="POST" action="/contact" class="rounded-4 shadow-sm p-4 bg-light fade-in-card">
        <div class="mb-3">
            <label for="name" class="form-label fw-semibold">Your Name</label>
            <input type="text" class="form-control rounded-pill classy-input" id="name" name="name" required>
        </div>
        <div class="mb-3">
            <label for="email" class="form-label fw-semibold">Your Email</label>
            <input type="email" class="form-control rounded-pill classy-input" id="email" name="email" required>
        </div>
        <div class="mb-3">
            <label for="message" class="form-label fw-semibold">Message</label>
            <textarea class="form-control rounded-4 classy-input" id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn btn-outline-dark rounded-pill px-4 classy-btn">
            <i class="bi bi-send me-1"></i> Send Message
        </button>
    </form>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<!-- Fade-in Animation -->
<style>
    .fade-in-card { opacity: 0; transform: translateY(20px); transition: all 0.6s ease-in-out; }
    .fade-in-card.visible { opacity: 1; transform: translateY(0); }
</style>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".fade-in-card").forEach(card => {
            card.classList.add("visible");
        });
    });
</script>
</body>
</html>