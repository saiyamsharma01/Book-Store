<!-- views/admin/dashboard.ejs -->

<h2 class="mt-4 mb-3 text-secondary fw-bold d-flex align-items-center">
    <i class="bi bi-speedometer2 me-2 text-danger"></i> Admin Dashboard
</h2>

<div class="row">
    <!-- Books Panel -->
    <div class="col-md-6 mb-4 fade-in-card">
        <div class="card border-0 rounded-4 shadow-sm classy-card">
            <div class="card-header d-flex justify-content-between align-items-center bg-light fw-bold">
                <span><i class="bi bi-book me-2 text-primary"></i> Books</span>
                <a href="/admin/books/new" class="btn btn-sm btn-outline-primary rounded-pill classy-btn">
                    <i class="bi bi-plus-circle me-1"></i> Add Book
                </a>
            </div>
            <div class="card-body">
                <% if (books && books.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-sm table-striped align-middle classy-table">
                            <thead class="table-dark">
                            <tr>
                                <th>Title</th>
                                <th>Author</th>
                                <th>Price</th>
                                <th>Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            <% books.slice(0, 5).forEach(b => { %>   <!-- ✅ Only show first 5 -->
                            <tr>
                                <td><%= b.title %></td>
                                <td><%= b.author %></td>
                                <td class="fw-bold text-success">₹<%= b.price %></td>
                                <td>
                                    <a href="/admin/books/<%= b.id %>/edit" class="btn btn-sm btn-outline-warning rounded-pill classy-btn">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <form method="post" action="/admin/books/<%= b.id %>/delete" class="d-inline"
                                          onsubmit="return confirm('Delete <%= b.title %>?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill classy-btn">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <!-- View All Books Button -->
                    <div class="text-end mt-3">
                        <a href="/admin/books" class="btn btn-outline-primary rounded-pill classy-btn">
                            <i class="bi bi-book-half me-1"></i> View All Books
                        </a>
                    </div>
                <% } else { %>
                    <div class="alert alert-info rounded-4 shadow-sm d-flex align-items-center">
                        <i class="bi bi-info-circle me-2"></i> No books found. Add one above.
                    </div>
                <% } %>
            </div>
        </div>
    </div>


    <!-- Categories Panel -->
    <div class="col-md-6 mb-4 fade-in-card">
        <div class="card border-0 rounded-4 shadow-sm classy-card">
            <div class="card-header d-flex justify-content-between align-items-center bg-light fw-bold">
                <span><i class="bi bi-tags me-2 text-primary"></i> Categories</span>
                <a href="/admin/categories/new" class="btn btn-sm btn-outline-primary rounded-pill classy-btn">
                    <i class="bi bi-plus-circle me-1"></i> Add Category
                </a>
            </div>
            <div class="card-body">
                <% if (categories && categories.length > 0) { %>
                    <ul class="list-group list-group-flush">
                        <% categories.slice(0, 5).forEach(c => { %>   <!-- ✅ Only show first 5 -->
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>
                                <% if (c.icon) { %>
                                    <img src="<%= c.icon %>" alt="<%= c.name %> icon" width="30" height="30" class="me-2">
                                <% } %>
                                <%= c.name %>
                            </span>
                            <div>
                                <a href="/admin/categories/<%= c.id %>/edit" class="btn btn-sm btn-outline-warning rounded-pill classy-btn">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form method="post" action="/admin/categories/<%= c.id %>/delete" class="d-inline"
                                      onsubmit="return confirm('Delete <%= c.name %>?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill classy-btn">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </div>
                        </li>
                        <% }) %>
                    </ul>

                    <!-- View All Categories Button -->
                    <div class="text-end mt-3">
                        <a href="/admin/categories" class="btn btn-outline-primary rounded-pill classy-btn">
                            <i class="bi bi-tags-fill me-1"></i> View All Categories
                        </a>
                    </div>
                <% } else { %>
                    <div class="alert alert-info rounded-4 shadow-sm d-flex align-items-center">
                        <i class="bi bi-info-circle me-2"></i> No categories found. Add one above.
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    </div>
</div>

<!-- Category Stats Panel -->
<div class="col-md-12 mb-4 fade-in-card">
    <div class="card border-0 rounded-4 shadow-sm classy-card">
        <div class="card-header fw-bold bg-light">
            <i class="bi bi-bar-chart me-2 text-primary"></i> Category Usage Stats
        </div>
        <div class="card-body">
            <% if (categoryStats && categoryStats.length > 0) { %>
                <table class="table table-sm table-bordered table-striped classy-table">
                    <thead class="table-dark">
                    <tr>
                        <th>Category</th>
                        <th>Book Count</th>
                    </tr>
                    </thead>
                    <tbody>
                    <% categoryStats.forEach(stat => { %>
                        <tr>
                            <td><%= stat.name %></td>
                            <td class="fw-bold"><%= stat.book_count %></td>
                        </tr>
                    <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <div class="alert alert-info rounded-4 shadow-sm d-flex align-items-center">
                    <i class="bi bi-info-circle me-2"></i> No category stats available.
                </div>
            <% } %>
        </div>
    </div>
</div>


<!-- Users Section -->
<div class="card border-0 rounded-4 shadow-sm classy-card mb-4">
    <div class="card-header bg-light fw-bold">
        <i class="bi bi-people me-2 text-primary"></i> Latest Users
    </div>
    <div class="card-body">
        <% if (users && users.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-sm table-striped table-hover align-middle classy-table">
                    <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Joined</th>
                    </tr>
                    </thead>
                    <tbody>
                    <% let hasCustomers = false; %>
                    <% users.forEach(user => { %>
                        <% if (user.role !== 'admin') { %> <!-- ✅ Skip admins -->
                        <% hasCustomers = true; %>
                        <tr>
                            <td><%= user.id %></td>
                            <td><%= user.name %></td>
                            <td><%= user.email %></td>
                            <td>
                                <span class="badge bg-secondary rounded-pill px-3">Customer</span>
                            </td>
                            <td>
                                <% if (user.created_at) { %>
                                    <%= new Date(user.created_at).toLocaleDateString() %>
                                <% } else { %>
                                    <span class="text-muted">—</span>
                                <% } %>
                            </td>
                        </tr>
                        <% } %>
                    <% }) %>

                    <% if (!hasCustomers) { %>
                        <tr>
                            <td colspan="5" class="text-center text-muted">No customers found.</td>
                        </tr>
                    <% } %>
                    </tbody>
                </table>
            </div>

            <!-- View All Users Button -->
            <div class="text-end mt-3">
                <a href="/admin/users" class="btn btn-outline-primary rounded-pill classy-btn">
                    <i class="bi bi-people-fill me-1"></i> View All Users
                </a>
            </div>
        <% } else { %>
            <div class="alert alert-info rounded-4 shadow-sm d-flex align-items-center">
                <i class="bi bi-info-circle me-2"></i> No users found.
            </div>
        <% } %>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Fade-in animation for cards
        const cards = document.querySelectorAll(".fade-in-card");
        const observer = new IntersectionObserver(entries => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("visible");
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.2 });
        cards.forEach(card => observer.observe(card));

        // Optional: nicer confirm dialogs (replace default confirm)
        const forms = document.querySelectorAll("form[onsubmit]");
        forms.forEach(form => {
            form.addEventListener("submit", e => {
                const msg = form.getAttribute("onsubmit").match(/'(.*?)'/)[1];
                if (!confirm(msg)) {
                    e.preventDefault();
                }
            });
        });
    });
</script>