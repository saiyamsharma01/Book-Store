<div class="container my-5 fade-in-card">
    <h2 class="mb-4 text-secondary fw-bold d-flex align-items-center">
        <i class="bi bi-search me-2 text-primary"></i> Search Results for "<%= query %>"
    </h2>

    <!-- Users Section -->
    <div class="card border-0 rounded-4 shadow-sm classy-card mb-4">
        <div class="card-header bg-light fw-bold">
            <i class="bi bi-people me-2 text-primary"></i> Users
        </div>
        <div class="card-body">
            <% if (users.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-sm table-striped table-hover align-middle classy-table">
                        <thead class="table-dark">
                        <tr><th>ID</th><th>Name</th><th>Email</th><th>Role</th></tr>
                        </thead>
                        <tbody>
                        <% users.forEach(user => { %>
                            <tr>
                                <td><%= user.id %></td>
                                <td><%= user.name %></td>
                                <td><%= user.email %></td>
                                <td><span class="badge bg-secondary rounded-pill px-3"><%= user.role %></span></td>
                            </tr>
                        <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="alert alert-info rounded-4 shadow-sm d-flex align-items-center">
                    <i class="bi bi-info-circle me-2"></i> No users found.
                </div>
            <% } %>
        </div>
    </div>

    <!-- Orders Section -->
    <div class="card border-0 rounded-4 shadow-sm classy-card">
        <div class="card-header bg-light fw-bold">
            <i class="bi bi-receipt me-2 text-primary"></i> Orders
        </div>
        <div class="card-body">
            <% if (orders.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-sm table-striped table-hover align-middle classy-table">
                        <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Customer</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th>Payment Mode</th>
                            <th>Address</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        <% orders.forEach(order => { %>
                            <tr>
                                <td><%= order.id %></td>
                                <td><%= order.customer_name %> (<%= order.email %>)</td>
                                <td>₹<%= order.total %></td>
                                <td>
                                    <% if (order.status === 'pending') { %>
                                        <span class="badge bg-warning text-dark rounded-pill px-3">Pending</span>
                                    <% } else if (order.status === 'shipped') { %>
                                        <span class="badge bg-info text-dark rounded-pill px-3">Shipped</span>
                                    <% } else if (order.status === 'delivered') { %>
                                        <span class="badge bg-success rounded-pill px-3">Delivered</span>
                                    <% } else if (order.status === 'cancelled') { %>
                                        <span class="badge bg-danger rounded-pill px-3">Cancelled</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary rounded-pill px-3"><%= order.status %></span>
                                    <% } %>
                                </td>
                                <td><%= new Date(order.created_at).toLocaleString() %></td>
                                <td>
                                    <ul class="mb-0">
                                        <% order.items.forEach(item => { %>
                                            <li><%= item.title %> × <%= item.quantity %></li>
                                        <% }) %>
                                    </ul>
                                </td>
                                <td><%= order.payment_mode %></td>
                                <td>
                                    <% if (order.street) { %>
                                        <small class="text-muted">
                                            <%= order.street %>, <%= order.city %>, <%= order.state %> - <%= order.zip %>
                                        </small>
                                    <% } else { %>
                                        <span class="text-muted">No address</span>
                                    <% } %>
                                </td>
                                <td>
                                    <!-- Update Status -->
                                    <form method="post" action="/admin/orders/<%= order.id %>/status" class="d-flex gap-2 align-items-center">
                                        <select name="status" class="form-select form-select-sm w-auto">
                                            <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                            <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %>>Shipped</option>
                                            <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>Delivered</option>
                                            <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-outline-primary rounded-pill classy-btn">
                                            <i class="bi bi-check-circle me-1"></i> Update
                                        </button>
                                    </form>

                                    <!-- Delete Order -->
                                    <form method="post" action="/admin/orders/<%= order.id %>/delete" class="mt-2"
                                          onsubmit="return confirm('Delete order #<%= order.id %>?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill classy-btn">
                                            <i class="bi bi-trash me-1"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="alert alert-info rounded-4 shadow-sm d-flex align-items-center">
                    <i class="bi bi-info-circle me-2"></i> No orders found.
                </div>
            <% } %>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".fade-in-card").forEach(card => {
            card.classList.add("visible");
        });
    });
</script>