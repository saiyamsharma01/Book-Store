<h2 class="mt-4 mb-3 text-secondary fw-bold d-flex align-items-center">
    <i class="bi bi-tags me-2 text-primary"></i> <%= category ? 'Edit Category' : 'Add New Category' %>
</h2>

<form method="post" action="<%= formAction %>" class="card border-0 rounded-4 shadow-sm classy-card p-4 fade-in-card">
    <!-- Category Name -->
    <div class="mb-3">
        <label class="form-label fw-semibold">
            <i class="bi bi-tag me-1 text-primary"></i> Category Name
        </label>
        <input name="name" class="form-control rounded-pill classy-input"
               value="<%= category?.name || '' %>" required>
    </div>

    <!-- Description -->
    <div class="mb-3">
        <label class="form-label fw-semibold">
            <i class="bi bi-pencil-square me-1 text-primary"></i> Description
        </label>
        <textarea name="description" class="form-control classy-input" rows="3"><%= category?.description || '' %></textarea>
    </div>

    <!-- Icon URL -->
    <div class="mb-3">
        <label class="form-label fw-semibold">
            <i class="bi bi-image me-1 text-primary"></i> Icon URL
        </label>
        <input name="icon" class="form-control rounded-pill classy-input" value="<%= category?.icon || '' %>">
        <% if (category?.icon) { %>
            <div class="mt-3">
                <img src="<%= category.icon %>" alt="Category Icon"
                     class="img-thumbnail rounded shadow-sm" width="80">
            </div>
        <% } %>
    </div>

    <!-- Submit -->
    <button type="submit" class="btn btn-success w-100 rounded-pill classy-btn pulse-btn">
        <i class="bi bi-check-circle me-2"></i> <%= category ? 'Update Category' : 'Create Category' %>
    </button>
</form>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".fade-in-card").forEach(card => {
            card.classList.add("visible");
        });
    });
</script>