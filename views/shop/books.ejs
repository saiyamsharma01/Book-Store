<div class="container my-5 classy-section">
    <!-- Page Title -->
    <h2 class="mb-4 text-secondary fw-bold border-bottom pb-2 d-flex align-items-center">
        <i class="bi bi-book me-2 text-primary"></i> All Books
    </h2>

    <!-- Books Grid -->
    <div class="row g-4"> <!-- ✅ added gutter spacing -->
        <% if (books && books.length > 0) { %>
            <% books.forEach(b => { %>
                <div class="col-lg-2 col-md-3 col-sm-6 fade-in-card"> <!-- ✅ responsive columns -->
                    <div class="card h-100 border-0 rounded-4 shadow-sm classy-card hover-zoom">
                        <!-- Book Image -->
                        <a href="/book/<%= b.id %>">
                            <img src="<%= b.image || '/images/default-book.png' %>"
                                 alt="<%= b.title %>"
                                 class="card-img-top rounded-top"
                                 style="height:160px; object-fit:cover;">
                        </a>

                        <!-- Book Details -->
                        <div class="card-body d-flex flex-column p-3">
                            <h6 class="card-title mb-1 text-truncate">
                                <a href="/book/<%= b.id %>" class="text-decoration-none text-dark fw-semibold classy-link">
                                    <%= b.title %>
                                </a>
                            </h6>
                            <small class="text-muted">By <%= b.author %></small>
                            <p class="fw-bold text-success mb-2">₹<%= b.price %></p>

                            <!-- Stock Message -->
                            <% if (b.stock === 0) { %>
                                <p class="text-danger fw-bold mb-2">
                                    <i class="bi bi-x-circle me-1"></i> Out of Stock
                                </p>
                            <% } else if (b.stock <= 10) { %>
                                <p class="text-warning fw-bold mb-2">
                                    <i class="bi bi-exclamation-triangle me-1"></i> Only <%= b.stock %> left
                                </p>
                            <% } else { %>
                                <p class="text-muted mb-2">
                                    <i class="bi bi-check-circle me-1"></i> In Stock
                                </p>
                            <% } %>

                            <!-- Action Button -->
                            <a href="/book/<%= b.id %>"
                               class="btn btn-sm btn-outline-dark rounded-pill px-3 classy-btn mt-auto">
                                <i class="bi bi-eye me-1"></i> Details
                            </a>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12">
                <div class="alert alert-info rounded-4 shadow-sm text-center">
                    <i class="bi bi-info-circle me-2"></i> No books found.
                </div>
            </div>
        <% } %>
    </div>

    <!-- Pagination Controls -->
    <% if (totalPages && totalPages > 1) { %>
        <nav aria-label="Books pagination">
            <ul class="pagination justify-content-center mt-4">
                <% if (page > 1) { %>
                    <li class="page-item">
                        <a class="page-link rounded-pill classy-btn" href="/books?page=<%= page - 1 %>">
                            <i class="bi bi-arrow-left me-1"></i> Previous
                        </a>
                    </li>
                <% } %>

                <% for (let i = 1; i <= totalPages; i++) { %>
                    <li class="page-item <%= page === i ? 'active' : '' %>">
                        <a class="page-link rounded-pill classy-btn" href="/books?page=<%= i %>"><%= i %></a>
                    </li>
                <% } %>

                <% if (page < totalPages) { %>
                    <li class="page-item">
                        <a class="page-link rounded-pill classy-btn" href="/books?page=<%= page + 1 %>">
                            Next <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </li>
                <% } %>
            </ul>
        </nav>
    <% } %>
</div>

<script>
    // Fade-in animation
    document.addEventListener("DOMContentLoaded", () => {
        const cards = document.querySelectorAll(".fade-in-card");
        const observer = new IntersectionObserver(entries => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("visible");
                    observer.unobserve(entry.target); // animate once
                }
            });
        }, { threshold: 0.2 });
        cards.forEach(card => observer.observe(card));
    });
</script>