<div class="container py-5">
    <!-- Page Title -->
    <div class="d-flex align-items-center mb-5 pb-3 border-bottom border-1" style="border-color: var(--border-color) !important;">
        <div class="me-3 d-flex align-items-center justify-content-center bg-white rounded-circle shadow-sm" style="width: 50px; height: 50px;">
            <i class="bi bi-book text-primary fs-4" style="color: var(--accent) !important;"></i>
        </div>
        <div>
            <h1 class="h2 mb-0 brand-font fw-bold" style="font-size: 2.25rem;">All Books Catalog</h1>
            <p class="text-muted mb-0 small" style="font-size: 0.9rem;">Browse through our extensive library of handpicked titles.</p>
        </div>
    </div>

    <!-- Books Grid -->
    <div class="row g-4">
        <% if (books && books.length > 0) { %>
            <% books.forEach(b => { %>
                <div class="col-lg-3 col-md-4 col-sm-6 fade-in-card">
                    <div class="card h-100 classy-card">
                        <!-- Book Cover Image -->
                        <a href="/book/<%= b.id %>" class="card-img-wrapper">
                            <% if (b.image) { %>
                                <img src="<%= b.image.startsWith('http') || b.image.startsWith('/uploads/books/') ? b.image : '/uploads/books/' + b.image %>"
                                     alt="<%= b.title %>">
                            <% } else { %>
                                <img src="/images/default-book.png"
                                     alt="No cover">
                            <% } %>
                        </a>

                        <!-- Book Details -->
                        <div class="card-body d-flex flex-column p-4">
                            <h3 class="classy-card-title text-truncate" style="font-size: 1.35rem; margin-bottom: 0.25rem;">
                                <a href="/book/<%= b.id %>" class="text-decoration-none text-dark fw-bold">
                                    <%= b.title %>
                                </a>
                            </h3>
                            <p class="classy-card-author">By <%= b.author %></p>
                            
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="classy-card-price">₹<%= b.price %></span>
                                
                                <!-- Stock Message as Premium Badges -->
                                <% if (b.stock === 0) { %>
                                    <span class="badge badge-premium badge-premium-danger" style="font-size: 0.65rem;">
                                        Out of Stock
                                    </span>
                                <% } else if (b.stock <= 10) { %>
                                    <span class="badge badge-premium badge-premium-warning" style="font-size: 0.65rem;">
                                        Only <%= b.stock %> Left
                                    </span>
                                <% } else { %>
                                    <span class="badge badge-premium badge-premium-success" style="font-size: 0.65rem;">
                                        In Stock
                                    </span>
                                <% } %>
                            </div>

                            <!-- Action Button -->
                            <div class="mt-auto pt-2">
                                <a href="/book/<%= b.id %>"
                                   class="btn btn-premium btn-premium-outline py-2 w-100 rounded-pill" style="font-size: 0.85rem;">
                                    <i class="bi bi-eye me-1"></i> View Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12">
                <div class="alert alert-info rounded-4 border-0 shadow-sm text-center py-5" style="background-color: var(--bg-card); color: var(--text-muted); border: 1px solid var(--border-color) !important;">
                    <i class="bi bi-info-circle fs-3 mb-3 d-block text-secondary" style="color: var(--accent) !important;"></i>
                    <h5 class="fw-bold mb-1">No Books Found</h5>
                    <p class="mb-0 text-muted small">We couldn't find any books in our inventory matching this category.</p>
                </div>
            </div>
        <% } %>
    </div>

    <!-- Pagination Controls -->
    <% if (totalPages && totalPages > 1) { %>
        <nav aria-label="Books pagination" class="mt-5 pt-4">
            <ul class="pagination justify-content-center gap-2">
                <% if (page > 1) { %>
                    <li class="page-item">
                        <a class="btn btn-premium btn-premium-outline py-2 px-4 rounded-pill d-flex align-items-center gap-1" href="/books?page=<%= page - 1 %>" style="font-size: 0.85rem;">
                            <i class="bi bi-arrow-left"></i> Previous
                        </a>
                    </li>
                <% } %>

                <% for (let i = 1; i <= totalPages; i++) { %>
                    <li class="page-item">
                        <a class="btn py-2 px-3 rounded-pill <%= page === i ? 'btn-premium-accent text-white' : 'btn-premium-outline' %>" href="/books?page=<%= i %>" style="font-size: 0.85rem; font-weight: 600; width: 38px; height: 38px; display: inline-flex; align-items: center; justify-content: center; padding: 0 !important;">
                            <%= i %>
                        </a>
                    </li>
                <% } %>

                <% if (page < totalPages) { %>
                    <li class="page-item">
                        <a class="btn btn-premium btn-premium-outline py-2 px-4 rounded-pill d-flex align-items-center gap-1" href="/books?page=<%= page + 1 %>" style="font-size: 0.85rem;">
                            Next <i class="bi bi-arrow-right"></i>
                        </a>
                    </li>
                <% } %>
            </ul>
        </nav>
    <% } %>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const cards = document.querySelectorAll(".fade-in-card");
        const observer = new IntersectionObserver(entries => {
            entries.forEach((entry, i) => {
                if (entry.isIntersecting) {
                    setTimeout(() => {
                        entry.target.classList.add("visible");
                    }, i * 60);
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.05 });
        cards.forEach(card => observer.observe(card));
    });
</script>