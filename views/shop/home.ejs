<!-- Hero Section with Dynamic Canvas & Sound Controller -->
<section class="editorial-hero text-center d-flex align-items-center position-relative" style="min-height: 480px;">
    <!-- Particle Canvas Layer -->
    <canvas id="heroCanvas" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 1;"></canvas>

    <!-- Foreground Content -->
    <div class="container py-5 position-relative" style="z-index: 2;">
        <h1 class="display-2 mb-3 animate__animated animate__fadeInDown brand-font hero-title">Your Gateway to Knowledge</h1>
        <p class="lead mb-5 animate__animated animate__fadeInUp hero-subtitle">
            Discover thousands of curated books, from time-honored classics to today's bestsellers. Handpicked for the curious mind.
        </p>
        <div class="d-flex flex-column flex-sm-row justify-content-center gap-3 animate__animated animate__fadeInUp animate__delay-1s hero-btn-group">
            <a href="/books" class="btn btn-premium btn-premium-accent px-5 py-3 rounded-pill">Browse Collection</a>
            <a href="/categories" class="btn btn-premium btn-premium-outline py-3 px-5 rounded-pill text-white border-white" style="background-color: rgba(255,255,255,0.05);">Shop Categories</a>
        </div>
    </div>

    <!-- Sound Control Floating Badge -->
    <button id="soundToggleBtn" onclick="toggleAmbientSound()" class="btn btn-sm btn-premium d-flex align-items-center gap-2 border-0 shadow-sm" 
            style="position: absolute; bottom: 20px; right: 20px; z-index: 10; background: rgba(255,255,255,0.1); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); color: #ffffff; font-size: 0.8rem; padding: 0.5rem 1.2rem; border-radius: 50px;">
        <i class="bi bi-music-note-beamed" id="soundIcon" style="font-size: 1rem;"></i>
        <span id="soundText" style="font-weight: 600; font-family: 'Plus Jakarta Sans', sans-serif;">Play Bookstore Lofi</span>
        <div class="sound-wave d-none" id="soundWave">
            <span></span><span></span><span></span>
        </div>
    </button>

    <!-- Ambient Bookstore Soundtrack (Looping cozy lofi beats) -->
    <audio id="ambientAudio" src="/sounds/bookstore.mp3" loop></audio>
</section>

<!-- Latest Books Section -->
<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <span class="badge badge-premium badge-premium-success mb-2" style="font-size: 0.75rem;">New Releases</span>
                <h2 class="fw-bold mb-0 brand-font" style="font-size: 2.5rem; letter-spacing: -0.01em;">Latest Arrivals</h2>
                <p class="text-muted mb-0" style="font-size: 0.95rem;">Fresh stories and brilliant insights recently added to our catalog.</p>
            </div>
            <a href="/books" class="btn btn-link link-primary fw-bold text-decoration-none p-0 d-flex align-items-center gap-1" style="color: var(--accent) !important; font-size: 0.95rem;">
                View All Collection <i class="bi bi-arrow-right"></i>
            </a>
        </div>

        <div class="row g-4">
            <% books.slice(0, 4).forEach((b, index) => { %>
                <div class="col-12 col-sm-6 col-md-4 col-lg-3 fade-in-card">
                    <div class="card h-100 classy-card">
                        <!-- Book Cover Image -->
                        <div class="card-img-wrapper">
                            <% if (b.image) { %>
                                <img src="<%= b.image.startsWith('http') || b.image.startsWith('/uploads/books/') ? b.image : '/uploads/books/' + b.image %>"
                                     alt="<%= b.title %>">
                            <% } else { %>
                                <img src="/images/default-book.png"
                                     alt="No cover">
                            <% } %>
                            
                            <div class="position-absolute top-0 end-0 p-3">
                                <span class="badge bg-white text-dark rounded-pill shadow-sm fw-semibold" style="font-size: 0.85rem; padding: 0.4rem 0.8rem; font-family: 'Plus Jakarta Sans', sans-serif;">
                                    ₹<%= b.price %>
                                </span>
                            </div>
                        </div>

                        <!-- Card Body -->
                        <div class="card-body p-4 d-flex flex-column">
                            <h3 class="classy-card-title text-truncate" style="font-size: 1.4rem;">
                                <a href="/book/<%= b.id %>" class="text-decoration-none text-dark">
                                    <%= b.title %>
                                </a>
                            </h3>
                            <p class="classy-card-author">By <%= b.author %></p>
                            
                            <div class="mt-auto d-grid pt-3">
                                <a href="/book/<%= b.id %>" class="btn btn-premium btn-premium-outline py-2 rounded-pill" style="font-size: 0.85rem;">View Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</section>

<!-- sound wave visualizer CSS style -->
<style>
    .animate__delay-1s { animation-delay: 0.5s; }
    
    .sound-wave {
        display: inline-flex;
        align-items: flex-end;
        gap: 2.5px;
        height: 12px;
        width: 14px;
        margin-left: 2px;
    }
    
    .sound-wave span {
        background-color: #ffffff;
        width: 2.5px;
        height: 100%;
        border-radius: 5px;
        animation: soundBounce 0.8s ease-in-out infinite alternate;
    }
    
    .sound-wave span:nth-child(2) { animation-delay: 0.2s; }
    .sound-wave span:nth-child(3) { animation-delay: 0.4s; }
    
    @keyframes soundBounce {
        0% { height: 3px; }
        100% { height: 12px; }
    }
</style>

<script>
    // ----------------- Sound Controller Logic -----------------
    function toggleAmbientSound() {
        const audio = document.getElementById('ambientAudio');
        const icon = document.getElementById('soundIcon');
        const text = document.getElementById('soundText');
        const wave = document.getElementById('soundWave');
        const btn = document.getElementById('soundToggleBtn');

        if (audio.paused) {
            audio.play().then(() => {
                icon.className = 'bi bi-pause-fill';
                text.textContent = 'Pause Music';
                wave.classList.remove('d-none');
                btn.style.background = 'rgba(194, 65, 12, 0.85)'; // Terracotta highlight on play
            }).catch(err => {
                console.error("Audio playback blocked by browser policies: ", err);
            });
        } else {
            audio.pause();
            icon.className = 'bi bi-music-note-beamed';
            text.textContent = 'Play Bookstore Lofi';
            wave.classList.add('d-none');
            btn.style.background = 'rgba(255, 255, 255, 0.1)';
        }
    }

    // ----------------- Canvas Spark Particles Animation -----------------
    document.addEventListener("DOMContentLoaded", () => {
        const canvas = document.getElementById('heroCanvas');
        const ctx = canvas.getContext('2d');
        let animationFrameId;

        // Resize Canvas
        function resizeCanvas() {
            const rect = canvas.parentElement.getBoundingClientRect();
            canvas.width = rect.width;
            canvas.height = rect.height;
        }
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);

        // Particle Class
        class Spark {
            constructor() {
                this.reset();
            }

            reset() {
                this.x = Math.random() * canvas.width;
                this.y = canvas.height + Math.random() * 50;
                this.size = Math.random() * 3 + 1;
                this.speedY = Math.random() * 0.8 + 0.3;
                this.speedX = (Math.random() - 0.5) * 0.3;
                this.opacity = Math.random() * 0.5 + 0.1;
                this.fadeRate = Math.random() * 0.002 + 0.001;
            }

            update() {
                this.y -= this.speedY;
                this.x += this.speedX;
                this.opacity -= this.fadeRate;

                if (this.opacity <= 0 || this.y < 0) {
                    this.reset();
                }
            }

            draw(color1, color2) {
                ctx.save();
                ctx.globalAlpha = this.opacity;
                
                // Radial glow for particle
                const grad = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, this.size * 2);
                grad.addColorStop(0, color1);
                grad.addColorStop(1, color2);
                
                ctx.fillStyle = grad;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size * 2, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            }
        }

        // Generate Particles List
        const sparkCount = window.innerWidth < 480 ? 15 : 35;
        const sparks = [];
        for (let i = 0; i < sparkCount; i++) {
            sparks.push(new Spark());
        }

        // Theme colors variables
        let pColor1 = 'rgba(249, 115, 22, 0.4)';  // Amber Spark core
        let pColor2 = 'rgba(234, 88, 12, 0)';    // transparent

        function updateParticleColors() {
            const theme = document.documentElement.getAttribute('data-theme') || 'custom';
            if (theme === 'dark') {
                pColor1 = 'rgba(249, 115, 22, 0.4)';
                pColor2 = 'rgba(234, 88, 12, 0)';
            } else if (theme === 'light') {
                pColor1 = 'rgba(37, 99, 235, 0.2)';
                pColor2 = 'rgba(59, 130, 246, 0)';
            } else { // custom / literary paper
                pColor1 = 'rgba(194, 65, 12, 0.3)';
                pColor2 = 'rgba(249, 115, 22, 0)';
            }
        }
        updateParticleColors();

        // Listen to Theme Changes using MutationObserver
        const themeObserver = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
                if (mutation.type === 'attributes' && mutation.attributeName === 'data-theme') {
                    updateParticleColors();
                }
            });
        });
        themeObserver.observe(document.documentElement, { attributes: true });

        // Animation Loop
        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            sparks.forEach(spark => {
                spark.update();
                spark.draw(pColor1, pColor2);
            });
            
            animationFrameId = requestAnimationFrame(animate);
        }
        animate();

        // Latest Arrivals Entrance Card Animations
        const cards = document.querySelectorAll(".fade-in-card");
        const cardObserver = new IntersectionObserver(entries => {
            entries.forEach((entry, i) => {
                if (entry.isIntersecting) {
                    setTimeout(() => {
                        entry.target.classList.add("visible");
                    }, i * 100);
                    cardObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.05 });
        cards.forEach(card => cardObserver.observe(card));
    });
</script>