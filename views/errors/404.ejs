<div class="container my-5 d-flex justify-content-center fade-in-card">
    <div class="card border-0 rounded-4 shadow-sm classy-card p-4 text-center" style="max-width: 600px; width: 100%;">
        <h1 class="display-5 fw-bold text-warning mb-3 d-flex align-items-center justify-content-center">
            <i class="bi bi-search me-2"></i>
            Page Not Found
        </h1>

        <p class="lead mb-3">
            <%= message || 'The page you are looking for does not exist.' %>
        </p>

        <hr class="my-4">

        <p class="text-muted mb-4">
            It might have been moved or deleted. Please check the URL or return to the homepage.
        </p>

        <div class="d-flex justify-content-center gap-3">
            <a href="/" class="btn btn-primary rounded-pill px-4 classy-btn">
                <i class="bi bi-house-door me-2"></i> Back to Home
            </a>
            <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4 classy-btn">
                <i class="bi bi-arrow-left-circle me-2"></i> Go Back
            </a>
        </div>
    </div>
</div>

<script>
    // Fade-in animation
    document.addEventListener("DOMContentLoaded", () => {
        const card = document.querySelector(".fade-in-card");
        if (card) card.classList.add("visible");
    });
</script>