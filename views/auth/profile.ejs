<div class="container my-5 classy-section">
    <!-- Page Title -->
    <h2 class="mb-4 text-secondary fw-bold border-bottom pb-2 d-flex align-items-center">
        <i class="bi bi-person-circle me-2 text-primary"></i> My Profile - MYBooks
    </h2>

    <!-- User Info -->
    <div class="card mb-4 border-0 rounded-4 shadow-sm classy-card fade-in-card">
        <div class="card-body row align-items-center">
            <div class="col-12 col-md-3 text-center mb-3 mb-md-0">
                <% if (user.avatar) { %>
                    <img src="<%= user.avatar %>" alt="Avatar"
                         class="rounded-circle border shadow-sm img-fluid"
                         style="max-width:120px; height:auto; object-fit:cover;">
                <% } else { %>
                    <img src="/images/default-avatar.png" alt="Avatar"
                         class="rounded-circle border shadow-sm img-fluid"
                         style="max-width:120px; height:auto; object-fit:cover;">
                <% } %>
            </div>
            <div class="col-12 col-md-9 text-center text-md-start">
                <h5 class="mb-1 fw-bold"><%= user.name %></h5>
                <p class="text-muted mb-0"><%= user.email %></p>
            </div>
        </div>
    </div>

    <!-- Update Profile -->
    <div class="card mb-4 border-0 rounded-4 shadow-sm classy-card fade-in-card">
        <div class="card-body">
            <h5 class="card-title fw-bold mb-3"><i class="bi bi-pencil-square me-2 text-primary"></i> Update Profile</h5>
            <form action="/auth/profile/update" method="POST" class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label fw-semibold">Name</label>
                    <input type="text" name="name" value="<%= user.name %>" class="form-control rounded-pill classy-input" required>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label fw-semibold">Email</label>
                    <input type="email" name="email" value="<%= user.email %>" class="form-control rounded-pill classy-input" required>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-sm btn-outline-primary rounded-pill classy-btn">
                        <i class="bi bi-check-circle me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Update Avatar -->
    <div class="card mb-4 border-0 rounded-4 shadow-sm classy-card fade-in-card">
        <div class="card-body">
            <h5 class="card-title fw-bold mb-3"><i class="bi bi-image me-2 text-primary"></i> Update Avatar</h5>
            <form action="/auth/profile/avatar" method="POST" enctype="multipart/form-data" class="row g-2">
                <div class="col-12 col-md-8">
                    <input type="file" name="avatar" class="form-control rounded-pill classy-input" required>
                </div>
                <div class="col-12 col-md-4">
                    <button type="submit" class="btn btn-sm btn-outline-secondary w-100 rounded-pill classy-btn">
                        <i class="bi bi-upload me-1"></i> Upload
                    </button>
                </div>
            </form>

            <% if (user.avatar) { %>
                <form action="/auth/profile/avatar/remove" method="POST"
                      onsubmit="return confirm('Remove your profile photo?');" class="mt-2">
                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill classy-btn">
                        <i class="bi bi-trash me-1"></i> Remove Photo
                    </button>
                </form>
            <% } else { %>
                <div class="alert alert-info rounded-4 shadow-sm mt-2">
                    <i class="bi bi-info-circle me-2"></i> Profile Picture Not Uploaded.
                </div>
            <% } %>
        </div>
    </div>

    <!-- Addresses -->
    <div class="card mb-4 border-0 rounded-4 shadow-sm classy-card fade-in-card">
        <div class="card-body">
            <h5 class="card-title fw-bold mb-3"><i class="bi bi-geo-alt me-2 text-primary"></i> My Addresses</h5>
            <a href="/auth/profile/address/new" class="btn btn-sm btn-outline-success rounded-pill classy-btn mb-3">
                <i class="bi bi-plus-circle me-1"></i> Add Address
            </a>
            <% if (addresses.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-sm align-middle classy-table">
                        <tbody>
                        <% addresses.forEach(addr => { %>
                            <tr>
                                <td><%= addr.street %>, <%= addr.city %>, <%= addr.state %> - <%= addr.zip %></td>
                                <td class="text-end">
                                    <!-- ✅ Flex container for alignment -->
                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="/auth/profile/address/edit/<%= addr.id %>"
                                           class="btn btn-sm btn-outline-warning rounded-pill classy-btn">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <form action="/auth/profile/address/delete/<%= addr.id %>" method="POST"
                                              onsubmit="return confirm('Delete this address?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill classy-btn">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="alert alert-info rounded-4 shadow-sm">
                    <i class="bi bi-info-circle me-2"></i> No addresses saved yet.
                </div>
            <% } %>
        </div>
    </div>
</div>

<script>
    // Fade-in animation
    document.addEventListener("DOMContentLoaded", () => {
        const cards = document.querySelectorAll(".fade-in-card");
        const observer = new IntersectionObserver(entries => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("visible");
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.2 });
        cards.forEach(card => observer.observe(card));
    });
</script>