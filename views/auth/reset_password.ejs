<div class="container my-5 d-flex justify-content-center fade-in-card">
    <div class="card border-0 rounded-4 shadow-sm classy-card p-4" style="max-width: 500px; width: 100%;">
        <h2 class="mb-4 text-center text-secondary fw-bold">
            <i class="bi bi-shield-lock me-2 text-primary"></i> Reset Password
        </h2>

        <% if (error) { %>
            <div class="alert alert-danger rounded-4 shadow-sm d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= error %>
            </div>
        <% } %>

        <% if (success) { %>
            <div class="alert alert-success rounded-4 shadow-sm d-flex align-items-center">
                <i class="bi bi-check-circle-fill me-2"></i> <%= success %>
            </div>
        <% } %>

        <form action="/auth/reset-password/<%= token %>" method="POST">
            <div class="mb-3">
                <label for="password" class="form-label fw-semibold">New Password</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-lock"></i></span>
                    <input type="password" name="password" id="password" class="form-control rounded-pill classy-input" required>
                </div>
            </div>

            <div class="mb-3">
                <label for="confirmPassword" class="form-label fw-semibold">Confirm Password</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-lock-fill"></i></span>
                    <input type="password" name="confirmPassword" id="confirmPassword" class="form-control rounded-pill classy-input" required>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 rounded-pill classy-btn pulse-btn">
                <i class="bi bi-check2-circle me-2"></i> Reset Password
            </button>
        </form>

        <p class="mt-3 text-center">
            Back to <a href="/auth/login" class="fw-semibold classy-link">Login</a>
        </p>
    </div>
</div>

<script>
    // Fade-in animation
    document.addEventListener("DOMContentLoaded", () => {
        const card = document.querySelector(".fade-in-card");
        card.classList.add("visible");
    });
</script>