<div class="container my-5 d-flex justify-content-center fade-in-card">
    <div class="card border-0 rounded-4 shadow-sm classy-card p-4" style="max-width: 600px; width: 100%;">
        <h2 class="mb-4 text-center text-secondary fw-bold">
            <i class="bi bi-pencil-square me-2 text-primary"></i> Edit Address
        </h2>

        <form action="/auth/profile/address/edit/<%= address.id %>" method="POST">
            <div class="mb-3">
                <label class="form-label fw-semibold">Street</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-house"></i></span>
                    <input type="text" name="street" value="<%= address.street %>" class="form-control rounded-pill classy-input" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">City</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-building"></i></span>
                    <input type="text" name="city" value="<%= address.city %>" class="form-control rounded-pill classy-input" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">State</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-map"></i></span>
                    <input type="text" name="state" value="<%= address.state %>" class="form-control rounded-pill classy-input" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">ZIP</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-mailbox"></i></span>
                    <input type="text" name="zip" value="<%= address.zip %>" class="form-control rounded-pill classy-input" required>
                </div>
            </div>

            <!-- Optional Default Address -->
            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" name="default" id="defaultAddress" <%= address.default ? 'checked' : '' %>>
                <label class="form-check-label" for="defaultAddress">
                    Set as Default Address
                </label>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <button type="submit" class="btn btn-primary rounded-pill classy-btn px-4">
                    <i class="bi bi-check-circle me-2"></i> Update Address
                </button>
                <a href="/auth/profile" class="btn btn-outline-secondary rounded-pill classy-btn px-4">
                    <i class="bi bi-x-circle me-2"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

<script>
    // Fade-in animation
    document.addEventListener("DOMContentLoaded", () => {
        const card = document.querySelector(".fade-in-card");
        card.classList.add("visible");
    });
</script>