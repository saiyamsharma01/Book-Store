<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Contact Admin - KBooks</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="container my-5 classy-section">
    <!-- Page Title -->
    <h1 class="fw-bold text-secondary mb-4 border-bottom pb-2 d-flex align-items-center">
        <i class="bi bi-person-lines-fill me-2 text-primary"></i> Contact Admin
    </h1>

    <!-- Contact Details -->
    <div class="card shadow-sm rounded-4 mb-4 fade-in-card">
        <div class="card-body">
            <p class="mb-2">
                <i class="bi bi-envelope-fill me-2 text-primary"></i>
                <strong>Email:</strong> <a href="mailto:admin@kbooks.com" class="text-decoration-none">admin@kbooks.com</a>
            </p>
            <p class="mb-2">
                <i class="bi bi-telephone-fill me-2 text-success"></i>
                <strong>Phone:</strong> <a href="tel:+919876543210" class="text-decoration-none">+91 98765 43210</a>
            </p>
            <p class="mb-2">
                <i class="bi bi-facebook me-2 text-info"></i>
                <strong>Facebook:</strong> <a href="https://facebook.com/kbooks" target="_blank">facebook.com/kbooks</a>
            </p>
            <p class="mb-2">
                <i class="bi bi-twitter-x me-2 text-info"></i>
                <strong>Twitter:</strong> <a href="https://twitter.com/kbooks" target="_blank">@kbooks</a>
            </p>
            <p class="mb-2">
                <i class="bi bi-instagram me-2 text-danger"></i>
                <strong>Instagram:</strong> <a href="https://instagram.com/kbooks" target="_blank">@kbooks</a>
            </p>
        </div>
    </div>

    <!-- Redirect Button -->
    <div class="text-center">
        <a href="/feedback" class="btn btn-outline-dark rounded-pill classy-btn">
            <i class="bi bi-chat-dots me-2"></i> Give Feedback
        </a>
    </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<!-- Fade-in Animation -->
<style>
    .fade-in-card { opacity: 0; transform: translateY(20px); transition: all 0.6s ease-in-out; }
    .fade-in-card.visible { opacity: 1; transform: translateY(0); }
</style>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".fade-in-card").forEach(card => {
            card.classList.add("visible");
        });
    });
</script>
</body>
</html>